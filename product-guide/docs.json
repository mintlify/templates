{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Product Guide",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "https://www.mintlify.com/docs/changelog"
        },
        {
          "anchor": "Help",
          "icon": "life-buoy",
          "href": "https://www.mintlify.com/docs/contact-support"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Getting started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "platform/quickstart",
          "platform/key-concepts"
        ]
      },
      {
        "group": "Configuration",
        "icon": "settings",
        "expanded": true,
        "pages": [
          "platform/configuration/settings",
          "platform/configuration/user-management"
        ]
      },
      {
        "group": "Administration",
        "icon": "shield-check",
        "expanded": true,
        "pages": [
          "platform/administration/roles-permissions",
          "platform/administration/audit-logs"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  }
}
